              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. John Smith\",\n  \"email\": \"dr.john@hospital.com\",\n  \"password\": \"doctor123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"ROLE_DOCTOR\",\n  \"specialization\": \"Cardiology\",\n  \"qualification\": \"MBBS, MD\",\n  \"experience\": 10,\n  \"consultationFee\": 500.00,\n  \"departmentId\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users"] }
          }
        },
