              "raw": "{\n  \"firstName\": \"Rahul\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"rahul.sharma@email.com\",\n  \"phone\": \"9876543210\",\n  \"dateOfBirth\": \"1990-05-15\",\n  \"gender\": \"MALE\",\n  \"bloodGroup\": \"B_POSITIVE\",\n  \"address\": \"123 Main Street, Mumbai\",\n  \"emergencyContactName\": \"Priya Sharma\",\n  \"emergencyContactPhone\": \"9876543211\"\n}"
