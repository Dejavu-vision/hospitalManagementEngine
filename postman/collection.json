    {
      "name": "📅 Appointments",
      "item": [
        {
          "name": "Book Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.environment.set('appointmentId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"doctorId\": {{doctorId}},\n  \"appointmentDate\": \"2026-03-20\",\n  \"appointmentTime\": \"10:00\",\n  \"type\": \"SCHEDULED\",\n  \"notes\": \"Regular checkup\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/appointments", "host": ["{{baseUrl}}"], "path": ["api", "appointments"] }
          }
        },
        {
          "name": "Walk-In Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.environment.set('appointmentId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"doctorId\": {{doctorId}},\n  \"notes\": \"Walk-in patient\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/appointments/walk-in", "host": ["{{baseUrl}}"], "path": ["api", "appointments", "walk-in"] }
          }
        },
        {
          "name": "Get Appointments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/appointments?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "date", "value": "2026-03-20", "disabled": true },
                { "key": "doctorId", "value": "1", "disabled": true },
                { "key": "status", "value": "SCHEDULED", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Available Slots",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/appointments/doctor/{{doctorId}}/slots?date=2026-03-20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "doctor", "{{doctorId}}", "slots"],
              "query": [{ "key": "date", "value": "2026-03-20" }]
            }
          }
        },
        {
          "name": "Get Today's Queue (Doctor)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/appointments/doctor/{{doctorId}}/today", "host": ["{{baseUrl}}"], "path": ["api", "appointments", "doctor", "{{doctorId}}", "today"] }
          }
        },
        {
          "name": "Update Appointment Status",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/status?status=COMPLETED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appointments", "{{appointmentId}}", "status"],
              "query": [{ "key": "status", "value": "COMPLETED" }]
            }
          }
        }
      ]
    },
    {
      "name": "🩺 Diagnosis",
      "item": [
