{
  "info": {
    "name": "CuraMatrix HSM - Multi-Tenant SaaS",
    "description": "Complete API collection for CuraMatrix Hospital Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "2.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": { "type": "text/javascript", "exec": [""] }
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.environment.set('token', res.token);",
                  "  pm.environment.set('userId', res.userId);",
                  "  pm.environment.set('tenantId', res.tenantId);",
                  "  pm.environment.set('tenantKey', res.tenantKey);",
                  "  pm.environment.set('userRole', res.role);",
                  "  console.log('Token saved. Role:', res.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hospital1.com\",\n  \"password\": \"admin123\",\n  \"tenantKey\": \"HOSPITAL_001\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "🏥 Super Admin - Tenants",
      "item": [
        {
          "name": "Register New Hospital (Tenant)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hospitalName\": \"City General Hospital\",\n  \"tenantKey\": \"CITY_GENERAL\",\n  \"adminEmail\": \"admin@citygeneral.com\",\n  \"adminPassword\": \"admin123\",\n  \"adminFullName\": \"Hospital Admin\",\n  \"subscriptionPlan\": \"PROFESSIONAL\",\n  \"subscriptionEndDate\": \"2027-12-31\",\n  \"maxDoctors\": 50,\n  \"maxPatients\": 5000\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/super-admin/tenants", "host": ["{{baseUrl}}"], "path": ["api", "super-admin", "tenants"] }
          }
        },
        {
          "name": "Get All Tenants",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/super-admin/tenants", "host": ["{{baseUrl}}"], "path": ["api", "super-admin", "tenants"] }
          }
        },
        {
          "name": "Get Tenant By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/super-admin/tenants/1", "host": ["{{baseUrl}}"], "path": ["api", "super-admin", "tenants", "1"] }
          }
        },
        {
          "name": "Update Tenant",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hospitalName\": \"City General Hospital Updated\",\n  \"tenantKey\": \"CITY_GENERAL\",\n  \"subscriptionPlan\": \"ENTERPRISE\",\n  \"subscriptionEndDate\": \"2028-12-31\",\n  \"maxDoctors\": 100,\n  \"maxPatients\": 10000\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/super-admin/tenants/1", "host": ["{{baseUrl}}"], "path": ["api", "super-admin", "tenants", "1"] }
          }
        },
        {
          "name": "Suspend Tenant",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/super-admin/tenants/1/suspend", "host": ["{{baseUrl}}"], "path": ["api", "super-admin", "tenants", "1", "suspend"] }
          }
        },
        {
          "name": "Activate Tenant",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/super-admin/tenants/1/activate", "host": ["{{baseUrl}}"], "path": ["api", "super-admin", "tenants", "1", "activate"] }
          }
        },
        {
          "name": "Get Tenant Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/super-admin/tenants/1/stats", "host": ["{{baseUrl}}"], "path": ["api", "super-admin", "tenants", "1", "stats"] }
          }
        }
      ]
    },
    {
      "name": "👤 Admin - User Management",
      "item": [
        {
          "name": "Create Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.environment.set('doctorId', pm.response.json().id);",
                  "}"
